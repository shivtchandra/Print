# Public site URL (no trailing slash). Use your custom domain in production, e.g. https://fotopalace.in
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin Android APK (Capacitor): full URL the WebView opens — set when running `npm run cap:sync`
# Example: https://your-domain.com/admin/login
# CAPACITOR_SERVER_URL=

# Google Analytics 4 (gtag)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Search Console → HTML tag verification (content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Meta (Facebook) Pixel
# NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

NEXT_PUBLIC_WHATSAPP_NUMBER=919435051891
# Optional: override default social URLs from lib/config.ts
# NEXT_PUBLIC_INSTAGRAM_URL=
# NEXT_PUBLIC_FACEBOOK_URL=
# NEXT_PUBLIC_YOUTUBE_URL=
# Google Business / Maps review link (optional)
# NEXT_PUBLIC_GOOGLE_REVIEWS_URL=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
